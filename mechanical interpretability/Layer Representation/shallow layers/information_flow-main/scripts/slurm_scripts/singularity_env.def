Bootstrap: docker
From: nvidia/cuda:11.8.0-cudnn8-devel-rockylinux8

%labels
    AUTHOR oscar.skean@uky.edu
    Architecture x86_64

%environment
        export PATH="/usr/local/Miniconda3/bin:/usr/bin:/usr/local/bin:/usr/bin:/bin:"
        unset CONDA_DEFAULT_ENV
        export ANACONDA_HOME=/usr/local/Miniconda3
        export LC_ALL=C.UTF-8
        export LANG=C.UTF-8

%post
#this will install all necessary packages and prepare the container
    mkdir /project /pscratch /share /opt/ohpc mnt/gpfs2_16m /mnt/gpfs2_4m

    yum -y install bzip2 which wget curl git gcc make cmake patch diffutils file perl-Data-Dumper kernel-devel autoconf automake libtool pkgconfig java-11-openjdk-devel
    yum clean all

    export PATH=/usr/local/Miniconda3/bin:/usr/bin:$PATH

    #Install Miniconda
    wget https://repo.anaconda.com/miniconda/Miniconda3-latest-Linux-x86_64.sh -P /tmp
    sh /tmp/Miniconda3-latest-Linux-x86_64.sh -b -p /usr/local/Miniconda3
    export PATH=/usr/local/Miniconda3/bin:/usr/bin:$PATH
    conda update -y  conda

    conda config --add channels defaults
    conda config --add channels bioconda
    conda config --add channels conda-forge

    #Install
    conda create -n pytorch-2.2.2 pytorch==2.2.2 torchvision torchaudio python==3.10 -c pytorch -c nvidia -y
    source activate
    conda activate pytorch-2.2.2
    pip install --upgrade pip
    pip install packaging
    pip install mamba_ssm einops==0.5 matplotlib==3.7.0 numpy==1.23.5 pandas==1.5.3 patool==1.12 reformer-pytorch==1.4.4 scikit-learn==1.2.2 scipy==1.10.1 sktime==0.16.1 sympy==1.11.1 torch==2.2.2 tqdm==4.64.1
    pip install causal-conv1d
    pip install mteb
    pip install transformers
    pip install datasets
    pip install umap
    pip install accelerate
    pip install llm2vec
    pip install flash-attn --no-build-isolation

    git clone https://github.com/uk-cliplab/representation-itl.git
    cd representation-itl
    pip install -e .
    cd ..


%help
    A baseline container for Nvidia pytorch

%apprun pytorch222
        source activate pytorch-2.2.2
        exec "$@"
